# ─── 2. Visibility Graph ──────────────────────────────────────
def build_vg(ts):
    n = len(ts)
    G = nx.Graph()
    G.add_nodes_from(range(n))
    for i in range(n-1):
        G.add_edge(i, i+1)
    stk = []
    for i in range(n):
        while stk:
            j = stk[-1]
            G.add_edge(j, i)
            if ts[j] > ts[i]: break
            stk.pop()
        stk.append(i)
    return G

G_jj = build_vg(jj); print("VG jj:", G_jj.number_of_nodes(), G_jj.number_of_edges())
G_ai = build_vg(ai); print("VG ai:", G_ai.number_of_nodes(), G_ai.number_of_edges())

# ─── 3. Degree distribution + power-law ──────────────────────
def deg_dist(G):
    degs = [d for _,d in G.degree()]
    cnt = {}
    for d in degs: cnt[d] = cnt.get(d,0)+1
    n = G.number_of_nodes()
    ks = np.array(sorted(cnt)); ps = np.array([cnt[k]/n for k in ks])
    return ks, ps

def fit_pl(ks, ps, kmin=3):
    m = (ks>=kmin) & (ps>0)
    sl, ic, r, *_ = linregress(np.log(ks[m]), np.log(ps[m]))
    return -sl, ic, r**2, m

k_jj,p_jj = deg_dist(G_jj); γ_jj,ic_jj,r2_jj,m_jj = fit_pl(k_jj,p_jj)
k_ai,p_ai = deg_dist(G_ai); γ_ai,ic_ai,r2_ai,m_ai = fit_pl(k_ai,p_ai)
print(f"γ_jj={γ_jj:.5f} R²={r2_jj:.4f}  γ_ai={γ_ai:.5f} R²={r2_ai:.4f}")

# ─── 4. Community detection ──────────────────────────────────
def detect(G):
    cs = sorted(nx.community.greedy_modularity_communities(G), key=lambda c: min(c))
    Q  = nx.community.modularity(G, cs)
    cmap = {}
    for i,c in enumerate(cs):
        for v in c: cmap[v]=i
    return cs, Q, cmap

cs_jj, Q_jj, cm_jj = detect(G_jj)
cs_ai, Q_ai, cm_ai = detect(G_ai)
print(f"Communities jj={len(cs_jj)} Q={Q_jj:.4f}  ai={len(cs_ai)} Q={Q_ai:.4f}")

