# ─── 5. Community stats tables ───────────────────────────────
def comm_table(cs, ts, dates, label):
    rows=[]
    for i,c in enumerate(cs):
        ns=sorted(c); n=len(ns)
        rows.append(dict(Comm=i+1, Nodes=n,
                         Pct=f"{n/len(ts)*100:.4f}%",
                         Start=str(dates[ns[0]].date()),
                         End=str(dates[ns[-1]].date()),
                         Mean=round(ts[ns].mean(),1)))
    df2=pd.DataFrame(rows)
    print(f"\n{label}:"); print(df2.to_string(index=False))
    return df2

