# ── Fig5 & Fig6: VG network — force-directed, 30 pts ──
# This is the KEY fix: spring_layout shows community clustering visually
def plot_vg_network(ts_full, cs_full, cm_full, title, fname, n=30):
    ts=ts_full[:n]
    G_s=build_vg(ts)
    # community color for each node 0..n-1
    nc=[COLORS[cm_full.get(i,0)%len(COLORS)] for i in range(n)]
    
    fig,axes=plt.subplots(1,2,figsize=(14,6))
    fig.suptitle(title, fontsize=11, fontweight='bold')
    
    # Left: bar + orange visibility arcs
    ax=axes[0]
    ax.bar(range(n),ts,color='#4472C4',alpha=0.72,width=0.55,zorder=2)
    for (i,j2) in G_s.edges():
        if abs(i-j2)>1:
            ax.annotate('',xy=(j2,ts[j2]),xytext=(i,ts[i]),
                        arrowprops=dict(arrowstyle='-',color='orange',lw=0.7,
                                       connectionstyle='arc3,rad=-0.2'),zorder=3)
    for i in range(n-1):
        ax.plot([i,i+1],[ts[i],ts[i+1]],color='orange',lw=0.7,zorder=3)
    ax.set_xlabel('Time (day index)',fontsize=10)
    ax.set_ylabel('Composite Index',fontsize=10)
    ax.set_title(f'(a) Time Series with Visibility Lines\n(first {n} time points)',fontsize=10)
    ax.grid(True,axis='y',alpha=0.3,zorder=1)
    
    # Right: FORCE-DIRECTED layout — communities cluster visually
    ax2=axes[1]
    pos=nx.spring_layout(G_s, seed=42, k=1.8, iterations=80)
    # edge weights: thicker = shorter temporal distance
    widths=[max(0.2, 1.5-0.05*abs(u-v)) for u,v in G_s.edges()]
    nx.draw_networkx_edges(G_s,pos,ax=ax2,edge_color='#AAAAAA',
                           width=widths,alpha=0.55)
    nx.draw_networkx_nodes(G_s,pos,ax=ax2,
                           node_color=nc,node_size=160,alpha=0.92,
                           linewidths=0.5,edgecolors='white')
    nx.draw_networkx_labels(G_s,pos,ax=ax2,
                            labels={i:str(i) for i in range(n)},
                            font_size=5.5,font_color='black')
    ax2.set_title(f'(b) Visibility Graph — Force-Directed Layout\n(nodes coloured by community)',fontsize=10)
    ax2.axis('off')
    # legend: unique communities appearing in first n nodes
    seen={}
    for i in range(n):
        ci=cm_full.get(i,0)
        if ci not in seen: seen[ci]=i
    patches=[mpatches.Patch(color=COLORS[ci%len(COLORS)],label=f'Comm {ci+1}')
             for ci in sorted(seen.keys())]
    ax2.legend(handles=patches,loc='lower right',fontsize=7,
               title='Community',title_fontsize=7,ncol=2,framealpha=0.85)
    
    plt.tight_layout()
    fig.savefig(fname,dpi=150,bbox_inches='tight')
    plt.close(); print(f"Saved {fname}")

